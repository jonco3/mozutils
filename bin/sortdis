#!/usr/bin/env python3

import argparse
import fileinput
import os
import os.path
import re
import sys

parser = argparse.ArgumentParser(
    description = 'Sort objdump disassembly output to aid comparison')
parser.add_argument('--filter-gc', action='store_true',
                    help='Include only GC relevant functions')
parser.add_argument('files', metavar='FILE', nargs='*')
args = parser.parse_args();

GCFilters = ["js::gc::", "mark", "trace", "sweep", "arena", "finalize", "allocator"]

HomeDir = os.environ['HOME']

def isGCRelated(first_line):
    first_line = first_line.lower()
    for filter in GCFilters:
        if filter in first_line:
            return True
    return False

# Sort sections by function name and args, ignoring address and return type.
def sectionKey(section):
    first_line = section[0]
    words = first_line.split()
    if words and re.match(r"[0-9a-f]+", words[0], re.IGNORECASE):
        words.pop(0)
    while words and "(" not in words[0] and "<" not in words[0][1:]:
        words.pop(0)
    if not words:
        return first_line
    result = ' '.join(words)
    if result.startswith("<"):
        result = result[1:]
    return result

# Try to simplify lines to make the output a little more readable
BufferedLine = None
def processLine(line):
    # Replace tabs with spaces
    line = line.replace("\t", ' ')

    # Simplify types
    line = line.replace("js::gc::", "")
    line = line.replace("js::", "")

    # Normalise paths
    if line.startswith("; /"):
        path = line[2:]
        path = os.path.normpath(path)
        path = path.replace(HomeDir, '~')
        # This part is super hacky
        if path.startswith('~/work/'):
            if '/js/' in path:
                path = 'js/' + path.split('/js/')[1]
            elif '/dist/include/' in path:
                path = path.split('/dist/include/')[1]
        elif '/usr/include/' in path:
            path = path.split('/usr/include/')[1]
        line = "; " + path

    # Remove references to functions in branches
    if line.startswith(' ') and '<' in line and line.endswith('>'):
        line = line.split('<')[0]

    # Try to put comments following the content they reference
    global BufferedLine
    if line.startswith(';'):
        if BufferedLine:
            result = [BufferedLine]
            BufferedLine = line
            return result
        BufferedLine = line
        return []
    if BufferedLine:
        if len(line) > 58:
            result = [BufferedLine, line]
            BufferedLine = None
            return result
        line = line.ljust(58) + " " + BufferedLine
        BufferedLine = None
    return [line]

section = None
sections = []

for line in fileinput.input(args.files):
    line = line.rstrip()

    if line == "":
        section = None
        continue

    if line.startswith("Disassembly of section"):
        continue

    if section is None:
        section = []
        sections.append(section)

    section.append(line)

if args.filter_gc:
    sections = list(filter(lambda section: isGCRelated(section[0]), sections))

sections.sort(key = sectionKey)

for section in sections:
    #print(section[0], file=sys.stderr)
    #print("  " + sectionKey(section), file=sys.stderr)

    for line in section:
        for l in processLine(line):
            print(l)
    print()
